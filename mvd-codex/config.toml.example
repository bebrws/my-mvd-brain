# Optional: allow workspace-write sandbox sessions to read/write the default
# global memory file at ~/mvd.mv2 without escalating every mvd command.
# Use the narrowest parent directory you can tolerate; Codex currently accepts
# writable roots as directories, not individual files.
#
# sandbox_mode = "workspace-write"
#
# [sandbox_workspace_write]
# writable_roots = ["/Users/YOUR_USER"]

# Merge this into ~/.codex/config.toml, or start Codex with:
#   codex --enable codex_hooks
#
# Codex hooks are experimental in current Codex CLI builds. Without this flag,
# hooks.json is ignored and memory capture relies on AGENTS.md instructions.

[features]
codex_hooks = true
